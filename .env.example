# Copie este arquivo para ".env" e ajuste conforme o ambiente.
# O arquivo ".env" NÃO deve ser versionado (já está no .gitignore).

# Caminho do banco SQLite (fica fora do controle de versão).
PRINT_MONITOR_DB=data/print_monitor.db

# Backend de coleta padrao: "mock" (Fase 1) ou "snmp" (Fase 3 em diante).
PRINT_MONITOR_BACKEND=mock

# --- Parametros SNMP (usados a partir da Fase 3) ---
# Community string de leitura. Use valor ficticio em exemplos.
SNMP_COMMUNITY=public
SNMP_PORT=161
# Timeout (segundos) e numero de tentativas por leitura.
SNMP_TIMEOUT=2
SNMP_RETRIES=1
